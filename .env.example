# General Configuration for Asteria Home Server
# Non-sensitive environment variables - EXAMPLE FILE
# Copy this to .env and fill in your actual values

# Global Settings
TZ=Europe/London
SERVER_NAME=asteria
# Root for all stateful service data, on the LOCAL disk — never on NFS
# (SQLite + NFS locking do not mix; that's what killed mealie). Same value
# on server and Pi. Important data ships to the NAS via restic instead,
# see backup/README.md.
DATA=/var/lib/homelab
PLATFORM=linux/arm64

# Docker Images
UNBOUND_IMAGE=mvance/unbound-rpi:latest  # Use mvance/unbound:latest for amd64

# User/Group IDs (for file permissions)
PUID=1001
PGID=3001

# Tailscale Configuration
TS_AUTHKEY=your_actual_tailscale_auth_key_here
TS_HOSTNAME=asteria
TS_ARGS=--advertise-exit-node --advertise-routes=192.168.0.0/24

# Atuin Configuration
ATUIN_PORT=8888
ATUIN_OPEN_REGISTRATION=true
ATUIN_MAX_HISTORY_LENGTH=8192

# Vaultwarden Configuration
VAULTWARDEN_PORT=8080
VAULTWARDEN_DOMAIN=https://vault.lan
VAULTWARDEN_SIGNUPS_ALLOWED=true
# Admin panel token - protects /admin with a single secret (no login page)
# Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=your_long_random_admin_token_here

# Healthcheck Configuration
# These settings apply to all service healthchecks
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=30s

# Scarlett Discord bot Configuration (github.com/biscuitvixen/scarlett_ai)
# Bot + Lavalink run here; the LLM lives on the GPU host (the Spark).
SCARLETT_DISCORD_TOKEN=your_discord_bot_token_here
# Point at the Spark's OpenAI-compatible endpoint (llama-swap / vLLM). Model is
# the id llama-swap routes on. LLM_ENABLED=false runs her mute (no chat cog).
SCARLETT_LLM_ENABLED=true
SCARLETT_LLM_BASE_URL=http://spark.lan:8000/v1
SCARLETT_LLM_MODEL=your_model_id_here
SCARLETT_LLM_API_KEY=not-needed
# Optional: a guild id for instant slash-command sync (blank = global sync)
SCARLETT_GUILD_ID=
# Comma-separated guild ids where she may chat, and user ids exempt from limits
SCARLETT_CHAT_GUILD_IDS=
SCARLETT_OWNER_IDS=
# Any string; the bot and its Lavalink just have to agree
SCARLETT_LAVALINK_PASSWORD=youshallnotpass
# YouTube OAuth for the youtube-source plugin. Leave blank on first run, then
# read the refresh token from the lavalink logs (use a BURNER google account).
SCARLETT_YOUTUBE_OAUTH_REFRESH_TOKEN=
